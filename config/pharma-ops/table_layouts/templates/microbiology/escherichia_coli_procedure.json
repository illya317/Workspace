          "type": "line",
          "field_key": "layout/microbiology/ecoli/dilution_1_transfer_volume",
          "underline": true,
          "initial_chars": 2,
          "placeholder": "1",
          "default": "1"
        },
        {
          "type": "text",
          "text": "ml 至 0.9%无菌氯化钠溶液"
        },
        {
          "type": "line",
          "field_key": "layout/microbiology/ecoli/dilution_1_diluent_volume",
          "underline": true,
          "initial_chars": 2,
          "placeholder": "9",
          "default": "9"
        },
        {
          "type": "text",
          "text": "ml 中（即为1:10）"
        },
        {
          "type": "text",
          "text": "，吸取上述菌液"
        },
        {
          "type": "line",
          "field_key": "layout/microbiology/ecoli/dilution_2_transfer_volume",
