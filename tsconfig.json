{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"],
      "@workspace/core": ["./packages/core/index.ts"],
      "@workspace/core/*": ["./packages/core/*"],
      "@workspace/platform": ["./packages/platform/index.ts"],
      "@workspace/platform/*": ["./packages/platform/*"],
      "@workspace/administration": ["./packages/administration/index.ts"],
      "@workspace/administration/*": ["./packages/administration/*"],
      "@workspace/library": ["./packages/library/index.ts"],
      "@workspace/library/*": ["./packages/library/*"],
      "@workspace/hr": ["./packages/hr/index.ts"],
      "@workspace/hr/*": ["./packages/hr/*"],
      "@workspace/production": ["./packages/production/index.ts"],
      "@workspace/production/*": ["./packages/production/*"],
      "@workspace/finance": ["./packages/finance/index.ts"],
      "@workspace/finance/*": ["./packages/finance/*"],
      "@workspace/work": ["./packages/work/index.ts"],
      "@workspace/work/*": ["./packages/work/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
