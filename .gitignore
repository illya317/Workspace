# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — .env.example is committed as documentation;
# all other .env files (local secrets) must stay ignored.
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# SQLite database (contains sensitive user data)
/prisma/dev.db
/prisma/dev.db-journal
/prisma/*.db
/prisma/*.db-journal

# Company-specific assets (logo, favicon, etc.)
/public/company/

# Planning files (local working memory)
/task_plan.md
/findings.md
/progress.md
/.planning/
