#!/bin/sh
# Pre-commit hook: mirror GitHub CI before recording a commit.

echo "→ Running CI checks before commit..."
node scripts/check/check-core-ui-guard.js --staged || {
  echo "✗ Core UI guard failed. Commit aborted."
  exit 1
}

npm run check:ci || {
  echo "✗ CI checks failed. Commit aborted."
  exit 1
}

ci_tree="$(git write-tree)"
ci_stamp="$(git rev-parse --git-path workspace-check-ci-ok)"
printf '%s\n' "$ci_tree" > "$ci_stamp"

echo "✓ Pre-commit CI checks passed."
