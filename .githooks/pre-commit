#!/bin/sh
# Pre-commit hook: keep local-only checks fast and leave heavy build work to CNB CI

echo "→ Running env check..."
npm run env:check || {
  echo "✗ Env check failed. Commit aborted."
  exit 1
}

echo "→ Running architecture governance check..."
npm run arch:check || {
  echo "✗ Architecture governance check failed. Commit aborted."
  exit 1
}

echo "→ Running Prisma schema validate..."
npm run db:validate || {
  echo "✗ Prisma schema validation failed. Commit aborted."
  exit 1
}

echo "→ Running schema governance check..."
npm run schema:check || {
  echo "✗ Schema governance check failed. Commit aborted."
  exit 1
}

echo "→ Running file size check..."
npm run size:check || {
  echo "✗ File size check failed. Commit aborted."
  exit 1
}

echo "→ Running lint (max-warnings=0)..."
npm run lint -- --max-warnings=0 || {
  echo "✗ Lint failed. Commit aborted."
  exit 1
}

echo "→ Running type check..."
npx tsc --noEmit || {
  echo "✗ Type check failed. Commit aborted."
  exit 1
}

echo "✓ Pre-commit checks passed."
