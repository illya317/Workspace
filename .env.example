# Required for production build and JWT cookie signing.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Runtime config root. Keep it outside the source checkout.
WORKSPACE_CONFIG_DIR=/path/to/your/.workspace

# Prisma SQLite database URL. Must be an absolute file: path under WORKSPACE_CONFIG_DIR/data.
DATABASE_URL="file:/path/to/your/.workspace/data/dev.db"

# Optional: public-facing app name (used in page titles and UI).
# NEXT_PUBLIC_APP_NAME=工作台

# Optional: public-facing company name (used in logos and alt text).
# NEXT_PUBLIC_COMPANY_NAME=丰华生物

# Public base path for the app when deployed below a sub-path.
NEXT_PUBLIC_BASE_PATH=/workspace

# 企业微信登录（自建应用）
# WECHAT_CORP_ID=wwxxxxxxxxxxxxxxxx
# WECHAT_AGENT_ID=1000000
# WECHAT_SECRET=xxxxxxxxxxxxxxxx
# Optional: force OAuth callback origin when behind a reverse proxy.
# WECHAT_REDIRECT_ORIGIN=https://your-domain.example.com

# QC 配置源覆盖（只读）。默认读取 WORKSPACE_CONFIG_DIR/config/pharma-qc。
# WORKSPACE_QC_CONFIG_ROOT=/path/to/workspace/.workspace/config/pharma-qc

# 资料库（本地文件浏览器）配置
# 试验版：支持通过环境变量适配任意本地文件夹
# LIBRARY_ROOT — 文件根目录，多个路径用英文逗号分隔（未来扩展）
# LIBRARY_ROOT=/path/to/library
# LIBRARY_LABEL — 页面标题（默认"资料库"）
# LIBRARY_LABEL=资料库

# 本地数据导入脚本（scripts/import/*）使用的输入/输出目录
# COMPANY_TASK_PLANS_INPUT_DIR=/path/to/company-task-plans/RAW
# COMPANY_TASK_PLANS_OUTPUT_DIR=/path/to/company-task-plans

# MiniMax LLM（Agent 智能助手，Anthropic Messages API 兼容）
# MINIMAX_API_KEY=sk-xxx
# MINIMAX_BASE_URL=https://api.minimaxi.com/anthropic
# MINIMAX_MODEL=MiniMax-M3
