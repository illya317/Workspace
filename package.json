{
  "name": "workspace",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "node scripts/check/with-check-lock.js -- npm run build:inner",
    "build:inner": "npm run db:generate:inner && next build",
    "build:next": "node scripts/check/with-check-lock.js -- next build",
    "start": "next start",
    "lint": "node scripts/check/with-check-lock.js -- eslint --cache --cache-location .cache/eslint/.eslintcache",
    "lint:changed": "node scripts/check/with-check-lock.js -- node scripts/check/run-eslint-changed.js",
    "complexity:line-budget": "node scripts/check/with-check-lock.js -- node scripts/check/check-net-line-growth.js",
    "complexity:net-growth": "npm run complexity:line-budget",
    "complexity:split-quality": "node scripts/check/with-check-lock.js -- node scripts/check/check-split-quality.js",
    "lint:net-lines": "npm run complexity:line-budget",
    "lint:full": "npm run lint -- --max-warnings=0",
    "typecheck:quick": "node scripts/check/with-check-lock.js -- npx tsc --noEmit --incremental --pretty false",
    "typecheck:full": "node scripts/check/with-check-lock.js -- npx tsc --noEmit",
    "check:changed": "npm run lint:changed && npm run typecheck:quick",
    "check:refactor": "npm run complexity:split-quality && npm run lint:changed && npm run typecheck:quick",
    "check:cleanup": "npm run check:refactor",
    "check:quick": "npm run env:check && npm run check:changed",
    "check:blockers": "npm run gate:domain && npm run gate:ui",
    "check:arch": "npm run check:blockers",
    "check:data": "npm run db:validate && npm run schema:check && npm run db:migration:check",
    "check:hygiene": "node scripts/check/run-hygiene-strict.js",
    "check:hygiene:warn": "node scripts/check/run-hygiene-warning.js",
    "check:ci": "npm run check:blockers && npm run env:check && npm run db:path:check && npm run docs:check && npm run check:data && npm run db:generate && npm run lint:full && npm run typecheck:full && npm run build:next && npm run check:hygiene:warn",
    "check:full": "npm run check:ci",
    "ci": "npm run check:ci",
    "test": "npm run typecheck:quick",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "arch:gate": "node scripts/check/with-check-lock.js -- tsx scripts/arch/gate.ts",
    "gate:domain": "node scripts/check/with-check-lock.js -- tsx scripts/arch/domain-gate.ts && npm run arch:structure:domain",
    "gate:ui": "node scripts/check/with-check-lock.js -- tsx scripts/arch/ui-gate.ts && npm run arch:structure:ui",
    "arch:structure": "tsx scripts/arch/level2.ts",
    "arch:structure:ratchet": "tsx scripts/arch/level2-enforce.ts",
    "arch:structure:domain": "tsx scripts/arch/level2-enforce.ts --scope=domain-blocker",
    "arch:structure:ui": "tsx scripts/arch/level2-enforce.ts --scope=ui-blocker",
    "arch:structure:hygiene": "tsx scripts/arch/level2-enforce.ts --scope=hygiene",
    "arch:level2": "npm run arch:structure",
    "arch:level2:ratchet": "npm run arch:structure:ratchet",
    "arch:level2:domain": "npm run arch:structure:domain",
    "arch:level2:ui": "npm run arch:structure:ui",
    "arch:level2:hygiene": "npm run arch:structure:hygiene",
    "db:check": "node scripts/check/check-db.js",
    "db:path:check": "node scripts/check/check-database-paths.js",
    "db:docs": "node scripts/generate/gen-db-docs.js",
    "db:resource-manifest": "npx tsx scripts/write-resource-manifest.ts",
    "db:seed:resources": "npx tsx scripts/seed-resources.ts",
    "db:generate": "node scripts/check/with-check-lock.js -- npm run db:generate:inner",
    "db:generate:inner": "prisma generate --schema=./prisma",
    "db:validate": "node scripts/check/with-check-lock.js -- prisma validate --schema=./prisma",
    "db:migration:check": "node scripts/check/with-check-lock.js -- node scripts/check/check-prisma-migrations.js",
    "db:format": "prisma format --schema=./prisma",
    "env:check": "node scripts/check/check-env.js",
    "workspace:check": "node scripts/check/check-workspace-runtime.js",
    "qc:cache:build": "npx tsx scripts/build-qc-template-cache.ts",
    "schema:check": "node scripts/check/with-check-lock.js -- node scripts/check/check-schema-governance.js",
    "api:check": "npm run arch:gate",
    "docs:check": "node scripts/check/with-check-lock.js -- node scripts/check/check-architecture-docs.js",
    "company:check": "node scripts/check/with-check-lock.js -- node scripts/check/check-company-hardcoding.js",
    "budget:sync-accounts": "node scripts/sync-budget-accounts.js",
    "finance:bs-diff": "npx tsx scripts/balance-sheet-diff.ts",
    "finance:bs-smoke": "npx tsx scripts/balance-sheet-diff.ts 02 2025 2 --top 20",
    "finance:bs-smoke:all": "npx tsx scripts/balance-sheet-smoke-all.ts",
    "finance:wp-smoke": "npx tsx scripts/statement-workpapers-smoke.ts",
    "finance:income-smoke": "npx tsx scripts/income-system-smoke.ts",
    "finance:review-report-smoke": "npx tsx scripts/review-report-smoke.ts",
    "finance:cashflow-import": "npx tsx scripts/import-cash-flow-workpapers.ts",
    "finance:cashflow-import:execute": "npx tsx scripts/import-cash-flow-workpapers.ts --execute",
    "work:company-tasks:clean": "npx tsx scripts/import/clean-company-task-plans.ts",
    "work:company-projects:import": "npx tsx scripts/import/import-company-priority-projects.ts",
    "db:seed:library-generated": "npx tsx scripts/seed-library-generated-sources.ts",
    "db:scan:library": "npx tsx scripts/scan-library.ts"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "iconv-lite": "^0.7.2",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/iconv-lite": "^0.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "prisma-docs-generator": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
