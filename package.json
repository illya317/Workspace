{
  "name": "weekly-report",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "ci": "npm run env:check && npm run db:validate && npm run schema:check && npm run lint -- --max-warnings=0 && npx tsc --noEmit && npm run build",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "arch:check": "node scripts/check-architecture-governance.js",
    "db:check": "node scripts/check-db.js",
    "db:docs": "node scripts/gen-db-docs.js",
    "db:validate": "prisma validate --schema=./prisma",
    "db:format": "prisma format --schema=./prisma",
    "env:check": "node scripts/check-env.js",
    "schema:check": "node scripts/check-schema-governance.js"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.3",
    "prisma-docs-generator": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
