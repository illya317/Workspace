{
  "name": "workspace",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "build": "prisma generate --schema=./prisma && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:changed": "node scripts/check/run-eslint-changed.js",
    "lint:full": "npm run lint -- --max-warnings=0",
    "typecheck:quick": "npx tsc --noEmit --incremental --pretty false",
    "typecheck:full": "npx tsc --noEmit",
    "check:quick": "npm run env:check && npm run api:check && npm run size:check && npm run lint:changed && npm run typecheck:quick",
    "check:full": "npm run arch:gate && npm run env:check && npm run db:path:check && npm run api:check && npm run docs:check && npm run db:validate && npm run schema:check && npm run company:check && npm run size:check && npm run lint:full && npm run typecheck:full && npm run build",
    "check:full:cnb": "CI=1 NEXTAUTH_SECRET=\"${NEXTAUTH_SECRET:-weekly-report-secret-key-2026-ci-only}\" sh -c 'npm run arch:gate && npm run db:path:check && npm run api:check && npm run docs:check && npm run db:validate && npm run schema:check && npm run company:check && npm run size:check && npm run lint:full && npm run typecheck:full && npm run build'",
    "ci": "npm run check:full",
    "ci:cnb": "npm run check:full:cnb",
    "test": "npm run typecheck:quick",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "arch:gate": "tsx scripts/arch/gate.ts",
    "db:check": "node scripts/check/check-db.js",
    "db:path:check": "node scripts/check/check-database-paths.js",
    "db:docs": "node scripts/generate/gen-db-docs.js",
    "db:validate": "prisma validate --schema=./prisma",
    "db:format": "prisma format --schema=./prisma",
    "env:check": "node scripts/check/check-env.js",
    "workspace:check": "node scripts/check/check-workspace-runtime.js",
    "workspace:pull": "bash ops/sync-runtime-from-server.sh",
    "workspace:push-config": "bash ops/sync-config-to-server.sh",
    "qc:cache:build": "npx tsx scripts/build-qc-template-cache.ts",
    "schema:check": "node scripts/check/check-schema-governance.js",
    "api:check": "node scripts/check/check-api-routes.js",
    "docs:check": "node scripts/check/check-architecture-docs.js",
    "company:check": "node scripts/check/check-company-hardcoding.js",
    "size:check": "node scripts/check/check-file-size.js",
    "budget:sync-accounts": "node scripts/sync-budget-accounts.js",
    "finance:bs-diff": "npx tsx scripts/balance-sheet-diff.ts",
    "finance:bs-smoke": "npx tsx scripts/balance-sheet-diff.ts 02 2025 2 --top 20",
    "finance:bs-smoke:all": "npx tsx scripts/balance-sheet-smoke-all.ts",
    "finance:wp-smoke": "npx tsx scripts/statement-workpapers-smoke.ts",
    "finance:income-smoke": "npx tsx scripts/income-system-smoke.ts",
    "finance:review-report-smoke": "npx tsx scripts/review-report-smoke.ts",
    "finance:cashflow-import": "npx tsx scripts/import-cash-flow-workpapers.ts",
    "finance:cashflow-import:execute": "npx tsx scripts/import-cash-flow-workpapers.ts --execute",
    "db:seed:library-generated": "npx tsx scripts/seed-library-generated-sources.ts",
    "db:scan:library": "npx tsx scripts/scan-library.ts"
  },
  "prisma": {
    "schema": "./prisma"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "iconv-lite": "^0.7.2",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "pinyin-pro": "^3.28.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/iconv-lite": "^0.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^7.8.0",
    "prisma-docs-generator": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "xlsx": "^0.18.5"
  }
}
