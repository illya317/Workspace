{
  "name": "合同专员",
  "departmentName": "销售部",
  "reportTo": "销售总监",
  "positionPurpose": "辅助公司销售人员完成销售工作。",
  "summary": "销售合同录入系统审批；合同及时收集、整理、归档；开具发票；准备资料；快递费用结算；业务经理后勤保障工作。",
  "headcount": "",
  "version": "02",
  "effectiveDate": "20/07/2023",
  "purpose": "明确合同专员工作职责",
  "scope": "适用于合同专员岗位人员",
  "documentSource": "PPA-GW1108合同专员岗位说明书02版.doc",
  "subordinates": [
    "无"
  ],
  "duties": [
    {
      "title": "合同录入系统",
      "items": [
        "收集OA系统上各业务经理发来的销售合同",
        "合同及时录入U8系统，各位领导审批",
        "合同审批完成后盖章并通知储运部发货"
      ]
    },
    {
      "title": "合同履行管理",
      "items": [
        "建立《合同履行一览表》",
        "对合同执行情况跟踪、督促",
        "发货单录入履行表",
        "执行完成的合同收集、整理、归档"
      ]
    },
    {
      "title": "开具发票",
      "items": [
        "根据发货单开具发票",
        "整理发票并邮寄给各商业公司",
        "发票邮寄情况通知各业务经理"
      ]
    },
    {
      "title": "准备资料",
      "items": [
        "更新我公司企业资料和产品资料",
        "开具法人授权委托书",
        "准备商业公司所需资料并邮寄"
      ]
    },
    {
      "title": "快递费用结算",
      "items": [
        "每月初核对快递单号，邮寄人及金额",
        "核对无误后逐级给领导签字审批后交于财务"
      ]
    },
    {
      "title": "后勤服务工作",
      "items": [
        "负责公司通知、文件和信息的上传下达",
        "协助业务经理对客户反馈的意见传递、处理",
        "领导交办的其它工作"
      ]
    }
  ],
  "managementDuties": [],
  "education": "本科及以上。",
  "major": "销售相关专业。",
  "experience": "2年以上销售内勤经验。",
  "training": "GMP法规培训、商务礼仪、商务谈判，沟通技巧培训、财务专业知识培训、办公软件学习。",
