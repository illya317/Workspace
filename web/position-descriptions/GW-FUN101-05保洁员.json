  "subordinates": [
    "无"
  ],
  "duties": [
    {
      "title": "厂区路面保洁",
      "items": [
        "每天早、中、晚检查打扫路面卫生，保持清洁"
      ]
    },
    {
      "title": "领导办公室保洁",
      "items": [
        "每天检查领导办公室卫生，保持清洁，关闭好门窗",
        "桌椅、电脑、电话等设备表面无灰尘，且摆放整齐",
        "地面、门窗无浮尘，墙角旮旯无蜘蛛网",
        "垃圾每天清理"
      ]
    },
    {
      "title": "会议室保洁",
      "items": [
        "每天检查打扫会议室卫生，随时保持清洁",
        "会议室不使用时关闭好门窗"
      ]
    },
    {
      "title": "办公楼、宿舍、卫生间公共区域保洁",
      "items": [
        "每天早、中、晚检查办公楼走廊、所有厕所卫生，保持清洁",
        "栏杆、地面、门窗无浮尘，墙角旮旯无蜘蛛网",
        "洗手池台盆面清洁无垢",
        "厕盆、便池无黄垢、无异味，便纸摆放",
        "垃圾每天清理"
      ]
    },
    {
      "title": "花木养护",
      "items": [
        "定期给会议室及走廊花木浇水、维护"
      ]
    }
  ],
