{
  "name": "保洁员",
  "departmentName": "行政部",
  "reportTo": "行政人事部经理",
  "positionPurpose": "办公区保洁，为员工提供整洁舒适的工作环境。",
  "summary": "确保公司环境的整洁、卫生、美观和安全，提升公司形象。",
  "headcount": "",
  "version": "03",
