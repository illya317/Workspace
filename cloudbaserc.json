{
  "version": "2.0",
  "envId": "fenghua-d4gtws3np46fb9fe2",
  "framework": {
    "name": "nextjs",
    "plugins": {
      "client": {
        "use": "@cloudbase/framework-plugin-container",
        "inputs": {
          "serviceName": "weekly-report",
          "servicePath": "/",
          "localPath": "./",
          "dockerfilePath": "Dockerfile",
          "containerPort": 3000,
          "envVariables": {
            "NODE_ENV": "production",
            "DATABASE_URL": "file:/data/dev.db",
            "NEXTAUTH_SECRET": "{{env.NEXTAUTH_SECRET}}"
          },
          "volumeMounts": {
            "cfs": {
              "mountPath": "/data"
            }
          }
        }
      }
    }
  }
}
