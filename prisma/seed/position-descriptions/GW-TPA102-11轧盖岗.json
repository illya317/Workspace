  "duties": [
    {
      "title": "按照岗位标准操作规程完成轧盖任务",
      "items": [
        "按照生产计划，准备轧盖用铝塑盖，转入灭菌岗位",
        "核对已灭菌的轧盖用具及铝塑盖",
        "核对转入分装制品名称、批号、规格、转入数量",
        "使用轧盖机对转入分装制品进行轧盖操作",
        "完成轧盖工作区域的清场、检查用电安全",
        "定置保管轧盖工具",
        "完成轧盖各项工作记录的填写"
      ]
    },
    {
      "title": "设备管理及其他工作",
      "items": [
        "检查维护保养生产设施、设备",
        "配合完成验证小组的相关验证",
        "完成车间其它临时性工作",
        "提出工作中的合理性建议",
        "完成轧盖岗位SOP文件的起草和修订",
        "参加车间和公司组织的相关培训",
        "负责各批产品的轧盖数据的输出，完成与管理员对数据的交接工作"
      ]
    }
  ],
