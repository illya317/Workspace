  "duties": [
    {
      "title": "按照标准操作规程完成贴标任务",
      "items": [
        "领取待贴标制品，按照《制剂车间制品包装指令》完成制品贴标工作",
        "核对制品的批号、生产日期、有效期至内容，检查贴标质量",
        "核对标签数及制品数，将贴标好的制品转入冷藏库",
        "贴标结束后清场，检查电、气安全",
        "定置保管贴标使用工具",
        "完成各项工作记录的填写"
      ]
    },
    {
      "title": "设备管理及其它工作",
      "items": [
        "完成设备的维护保养",
        "完成车间其它临时性工作",
        "提出工作中的合理性建议",
        "完成贴标岗位SOP文件的起草和修订",
        "参加车间和公司组织的相关培训"
      ]
    }
  ],
