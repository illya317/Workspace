  "duties": [
    {
      "title": "按照标准操作规程完成制品外观检查操作",
      "items": [
        "根据批包装指令，领取待灯检制品，核对制品品名、规格、批号、数量",
        "使用灯检仪完成制品的外观检查，记录合格总数和不合格总数",
        "核对制品合格数、不合格数、破损数是否与转入数相符",
        "销毁灯检不合格制品，灯检合格品转入冷藏库或转入下一工序",
        "完成外观检查后灯检仪的清洁和灯检间的清场",
        "完成各项工作记录的填写"
      ]
    },
    {
      "title": "设备管理及其他工作",
      "items": [
        "定期完成设备的维护保养",
        "完成车间其它临时性工作",
        "提出工作中的合理性建议",
        "参加车间和公司组织的相关培训",
        "完成灯检岗位SOP文件起草和修订"
      ]
    }
  ],
