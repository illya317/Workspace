  "duties": [
    {
      "title": "制定和更新标准操作规程",
      "items": [
        "编写和修订标准操作规程（SOP），确保符合GCP，ICH-GCP等法规要求",
        "定期审查SOP，确保其时效性及适用性"
      ]
    },
    {
      "title": "评估合作方及供应商",
      "items": [
        "对CRO、SMO及实验室等第三方进行评估，确保其有承接临床试验的人员及资源",
        "评估供应商资质"
      ]
    },
    {
      "title": "稽查",
      "items": [
        "制定稽查计划并组织实施",
        "负责对临床试验项目进行稽查，包括研究机构及公司内部文件，发现问题、制定纠正与预防措施（CAPA），确保临床试验按照试验方案、GCP、SOP及相关法规操作"
      ]
    },
    {
      "title": "沟通与协调",
      "items": [
        "与项目组、供应商、研究中心及监管部门等机构保持沟通，确保相关问题得到及时解决",
        "协调各部门，保证临床试验能够正确的实施和记录"
      ]
    }
  ],
