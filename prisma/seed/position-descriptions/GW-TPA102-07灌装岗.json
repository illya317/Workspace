  "duties": [
    {
      "title": "按照操作规程完成分装",
      "items": [
        "按生产计划准备分装用胶塞，转入灭菌岗位",
        "核对已灭菌的分装用具及胶塞",
        "按规定要求无菌组装分装用具并接收半成品的检验报告单",
        "使用灌装加塞机完成分装操作，转交制品至冻干机内",
        "完成分装机的清洁及分装区域的清场",
        "定置保管分装用具",
        "完成各项生产记录的填写"
      ]
    },
    {
      "title": "设备管理及其他工作",
      "items": [
        "检查维护保养生产设施、设备",
        "配合验证小组完成相关验证工作",
        "完成车间其他临时性工作",
        "提出工作中的合理性建议",
        "完成灌装（加塞）岗位SOP文件起草和修订",
        "参加车间和公司组织的相关培训",
        "负责各批产品的灌装数据的输出，完成与管理员对数据的交接工作"
      ]
    }
  ],
