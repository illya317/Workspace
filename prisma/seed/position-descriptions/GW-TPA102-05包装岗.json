  "duties": [
    {
      "title": "按照标准操作规程完成包装操作",
      "items": [
        "凭《制剂车间制品批包装指令》，领取包材，使用喷码机完成打码操作",
        "领取已贴标制品及喷码结束的外包材",
        "核对外包材上的打印信息和数量",
        "检查贴标合格的待包装品，核对品名、规格、批号、数量",
        "完成包装操作，转入冷藏库",
        "完成包装后工作区域的清场，定置保管包装用具，检查用电安全",
        "完成岗位各项工作记录的填写"
      ]
    },
    {
      "title": "完成其它工作",
      "items": [
        "提出工作中的合理性建议",
        "完成车间其他临时性工作",
        "完成岗位SOP文件的起草和修订",
        "定期完成设备的维护保养",
        "参加车间和公司组织的相关培训"
      ]
    }
  ],
