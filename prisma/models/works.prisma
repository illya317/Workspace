/// 工作清单条目
model WorkItem {
  id           Int               @id @default(autoincrement())
  targetType   String            @default("personal")
  targetId     Int?
  category     String
  content      String
  importance   Int               @default(3)
  urgency      Int               @default(3)
  isArchived   Boolean           @default(false)
  isPrivate    Boolean           @default(false)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  participants WorkParticipant[]

  @@index([targetType, targetId, category])
}

/// 工作清单参与人
model WorkParticipant {
  id         Int      @id @default(autoincrement())
  workItemId Int
  name       String
  wxUserId   String?
  createdAt  DateTime @default(now())
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

/// 部门工作指派人（业务配置，非 RBAC 权限）
model DepartmentWorkAssignee {
  id           Int        @id @default(autoincrement())
  departmentId Int
  userId       Int
  kind         String // "task"
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId, kind])
}

/// 项目工作指派人（业务配置，非 RBAC 权限）
model ProjectWorkAssignee {
  id        Int     @id @default(autoincrement())
  projectId Int
  userId    Int
  kind      String // "task"
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, kind])
}
