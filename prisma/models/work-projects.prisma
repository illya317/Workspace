/// 项目/虚拟团队
model Project {
  id                  Int                   @id @default(autoincrement())
  code                String?               @unique
  name                String
  type                String                @default("department")
  description         String?
  status              String?
  isMilestone         Boolean               @default(false)
  stage               String?
  plan                String?
  goal                String?
  milestones          String?
  budgetAmount        Float?
  budgetNote          String?
  riskNote            String?
  remark              String?
  startDate           DateTime?
  endDate             DateTime?
  parentId            Int?
  leadingDepartmentId Int?
  isArchived          Boolean               @default(false)
  archivedAt          DateTime?
  createdBy           Int?
  editedBy            Int?
  editedAt            DateTime?
  version             Int                   @default(1)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @default(now()) @updatedAt
  parent              Project?              @relation("ProjectHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children            Project[]             @relation("ProjectHierarchy")
  leadingDepartment   Department?           @relation("ProjectLeadingDepartment", fields: [leadingDepartmentId], references: [id], onDelete: SetNull)
  employees           EmployeeProject[]
  tasks               ProjectTask[]
  workAssignees       ProjectWorkAssignee[]

  @@index([parentId])
  @@index([leadingDepartmentId])
}

/// 员工-项目关联
model EmployeeProject {
  id         Int       @id @default(autoincrement())
  employeeId Int
  projectId  Int
  role       String?
  startDate  String?
  endDate    String?
  editedBy   Int?
  editedAt   DateTime?
  version    Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, projectId])
}

/// 项目任务计划
model ProjectTask {
  id                Int           @id @default(autoincrement())
  projectId         Int
  isMilestone       Boolean       @default(false)
  ownerEmployeeId   Int?
  description       String
  startDate         DateTime?
  endDate           DateTime?
  predecessorTaskId Int?
  sortOrder         Int           @default(0)
  createdBy         Int?
  editedBy          Int?
  editedAt          DateTime?
  version           Int           @default(1)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @default(now()) @updatedAt
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner             Employee?     @relation("ProjectTaskOwner", fields: [ownerEmployeeId], references: [id], onDelete: SetNull)
  predecessor       ProjectTask?  @relation("ProjectTaskDependency", fields: [predecessorTaskId], references: [id], onDelete: SetNull)
  successors        ProjectTask[] @relation("ProjectTaskDependency")

  @@index([projectId, sortOrder])
  @@index([ownerEmployeeId])
  @@index([predecessorTaskId])
}
