generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 用户与认证 ───────────────────────────────────────────

model User {
  id               Int               @id @default(autoincrement())
  wxUserId         String            @unique
  username         String?           @unique
  password         String?
  name             String
  employeeId       String?
  departmentId     Int               // 注册时初始关联线索，非权威来源
  departmentName   String?
  avatar           String?
  routineItems     String?
  isWorkListAdmin  Boolean           @default(false)
  canSelectAnyWeek Boolean           @default(false)
  canAccessHR      Boolean           @default(false)
  canAccessWorks   Boolean           @default(true)
  canLogin         Boolean           @default(true)  // 离职=停用，不删号
  apiKey           String?           @unique
  createdAt        DateTime          @default(now())
  resourceRoles    UserResourceRole[]
  reports          WeeklyReport[]
  employees        Employee[]
}

// ─── RBAC 权限 ────────────────────────────────────────────
// 详见 docs/rbac.md

model Resource {
  id          Int                @id @default(autoincrement())
  key         String             @unique   // "system" | "module.hr" | "module.works" | "department" | "report_group" | "field"
  name        String
  description String?
  sortOrder   Int                @default(0)
  roles       UserResourceRole[]
}

model Role {
  id          Int                @id @default(autoincrement())
  key         String             @unique   // "access" | "admin" | "write" | "read" | "member" | "viewer"
  name        String
  description String?
  sortOrder   Int                @default(0)
  assignments UserResourceRole[]
}

model UserResourceRole {
  id         Int       @id @default(autoincrement())
  userId     Int
  resourceId Int
  roleId     Int
  scopeId    String?   // null=全局开关(第2层), 有值=范围分配(第3层)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource  @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId, roleId, scopeId])
}

// ─── 周报模块 ─────────────────────────────────────────────

model ReportGroup {
  id           Int            @id @default(autoincrement())
  name         String
  description  String?
  sortOrder    Int            @default(0)
  departmentId Int?
  department   Department?    @relation(fields: [departmentId], references: [id])
  createdAt    DateTime       @default(now())
  reports      WeeklyReport[]
}

model WeeklyReport {
  id            Int             @id @default(autoincrement())
  userId        Int?
  reportGroupId Int?
  weekNumber    Int
  year          Int
  periodType    String          @default("weekly")
  scopeType     String          @default("department")  // 🗑️ 待废弃，统一走 reportGroupId
  scopeId       Int                                     // 🗑️ 待废弃
  taskName      String
  notes         String?
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  history       ReportHistory[]
  items         ReportItem[]
  reportGroup   ReportGroup?    @relation(fields: [reportGroupId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])

  @@unique([scopeType, scopeId, periodType, year, weekNumber])
}

model ReportItem {
  id         Int          @id @default(autoincrement())
  reportId   Int
  category   String
  plan       String
  completion String?
  nextGoal   String?
  sortOrder  Int
  workItemId Int?
  report     WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id        Int          @id @default(autoincrement())
  reportId  Int
  version   Int
  taskName  String
  notes     String?
  itemsJson String
  createdAt DateTime     @default(now())
  report    WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

// ─── 工作清单模块（独立） ─────────────────────────────────

model WorkItem {
  id           Int               @id @default(autoincrement())
  scopeType    String?           @default("department") // "report_group" | "department" | "personal"
  scopeId      Int?                                     // ReportGroup.id | Department.id | User.id
  category     String
  content      String
  importance   Int               @default(3)
  urgency      Int               @default(3)
  isArchived   Boolean           @default(false)
  isPrivate    Boolean           @default(false)        // personal 时默认仅自己可见
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants WorkParticipant[]

  @@index([scopeType, scopeId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement())
  workItemId Int
  name       String
  wxUserId   String?
  createdAt  DateTime @default(now())
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

// ─── 花名册与组织架构 ─────────────────────────────────────

model Employee {
  id            Int                @id @default(autoincrement())
  employeeId    String             @unique
  name          String
  alias         String?
  gender        String?
  ethnicity     String?
  hometown      String?
  politics      String?
  education     String?
  title         String?
  school        String?
  major         String?
  majorRelevant String?
  phone         String?
  office1       String?
  office2       String?
  office3       String?
  attendance1   String?
  attendance2   String?
  joinDate      String?
  nature        String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  leaveDate     String?
  status        String?            @default("在职")
  deleted       Boolean?           @default(false)
  deletedTime   String?
  deletedBy     String?
  userId        Int?
  user          User?              @relation(fields: [userId], references: [id])
  positions     EmployeePosition[]
  editedBy      Int?
  editedAt      DateTime?
  version       Int                @default(1)
}

model Department {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  name              String
  companyCode       String?            // → CompanyCode (migration: copy from company)
  level             Int
  parentId          Int?
  parent            Department?        @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]       @relation("DeptHierarchy")
  managerUserId     Int?               // 负责人 → User.id（有账号时关联）
  positions         DepartmentPosition[]
  employeePositions EmployeePosition[]
  reportGroups      ReportGroup[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime?
  editedBy          Int?
  editedAt          DateTime?
  version           Int                @default(1)
}

model Position {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  name              String
  companyCode       String?            // → CompanyCode (migration: copy from company)
  departments       DepartmentPosition[]
  employeePositions EmployeePosition[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime?
  editedBy          Int?
  editedAt          DateTime?
  version           Int                @default(1)
}

model EmployeePosition {
  id           Int        @id @default(autoincrement())
  employeeId   Int
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   Int
  position     Position   @relation(fields: [positionId], references: [id])
  companyCode  String?    // 该岗位上的业务公司编码 → CompanyCode
  center       String?
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  startDate    String?    // 任职开始日期
  endDate      String?    // 任职结束日期（null=至今）
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?
  editedBy     Int?
  editedAt     DateTime?
  version      Int        @default(1)
}

model DepartmentPosition {
  id           Int        @id @default(autoincrement())
  departmentId Int
  positionId   Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position     Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([departmentId, positionId])
}

// ─── 字典 ─────────────────────────────────────────────────

model CompanyCode {
  code String @id
  name String @unique
}

// ─── 编辑历史 ─────────────────────────────────────────────

model EditHistory {
  id         Int      @id @default(autoincrement())
  entityType String   // "employee" | "employee_position" | "code_department" | "code_position"
  entityId   String
  version    Int
  dataJson   String   // 编辑前快照
  editedBy   Int
  createdAt  DateTime @default(now())

  @@unique([entityType, entityId, version])
}
