generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              Int             @id @default(autoincrement())
  wxUserId        String          @unique
  username        String?         @unique
  password        String?
  name            String
  company         String?
  departmentId    Int
  departmentName  String?
  avatar          String?
  routineItems    String?         // JSON: [{plan, nextGoal}, ...] 日常工作模板
  isWorkListAdmin   Boolean         @default(false)
  canSelectAnyWeek  Boolean         @default(false)
  canAccessHR       Boolean         @default(false)
  canAccessWorks    Boolean         @default(true)
  employeeId        String?
  canLogin          Boolean         @default(true)
  apiKey            String?         @unique
  createdAt         DateTime        @default(now())
  reports         WeeklyReport[]
  fieldPermissions FieldPermission[]
  managedDepartments DepartmentAdmin[]
  positions         UserPosition[]
}

model ReportGroup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  members     ReportGroupMember[]
  viewers     ReportGroupViewer[]
  admins      ReportGroupAdmin[]
  reports     WeeklyReport[]
}

model ReportGroupAdmin {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)
  userId        Int

  @@unique([reportGroupId, userId])
}

model ReportGroupMember {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)
  userId        Int

  @@unique([reportGroupId, userId])
}

model ReportGroupViewer {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)
  userId        Int

  @@unique([reportGroupId, userId])
}

model WeeklyReport {
  id            Int       @id @default(autoincrement())
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  reportGroupId Int?
  reportGroup   ReportGroup? @relation(fields: [reportGroupId], references: [id])
  weekNumber    Int
  year          Int
  periodType    String    @default("weekly")
  scopeType     String    @default("department")
  scopeId       Int
  taskName      String
  notes         String?
  version       Int       @default(1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  items         ReportItem[]
  history       ReportHistory[]

  @@unique([scopeType, scopeId, periodType, year, weekNumber])
}

model ReportItem {
  id          Int       @id @default(autoincrement())
  reportId    Int
  report      WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  workItemId  Int?      // 关联工作清单ID，用于跨周追踪
  category    String    // "routine" | "non-routine"
  plan        String
  completion  String?
  nextGoal    String?
  sortOrder   Int
}

model ReportHistory {
  id        Int      @id @default(autoincrement())
  reportId  Int
  report    WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  version   Int
  taskName  String
  notes     String?
  itemsJson String   // JSON: [{category, plan, completion, nextGoal, sortOrder}, ...]
  createdAt DateTime @default(now())

  @@unique([reportId, version])
}

model WorkItem {
  id           Int      @id @default(autoincrement())
  departmentId Int
  category     String   // "routine" | "non-routine"
  content      String
  importance   Int      @default(3)
  urgency      Int      @default(3)
  isArchived   Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  participants WorkParticipant[]

  @@index([departmentId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement())
  workItemId Int
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  name       String
  wxUserId   String?
  createdAt  DateTime @default(now())

  @@index([workItemId])
}

model Employee {
  id            Int      @id @default(autoincrement())
  employeeId    String
  name          String
  company       String?
  center        String?
  dept1         String?
  dept2         String?
  position      String?
  gender        String?
  ethnicity     String?
  hometown      String?
  politics      String?
  education     String?
  title         String?
  school        String?
  major         String?
  majorRelevant String?
  phone         String?
  office1       String?
  office2       String?
  office3       String?
  attendance1   String?
  attendance2   String?
  joinDate      String?
  nature        String?
  status        String?  @default("在职")
  leaveDate     String?
  alias         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FieldPermission {
  id      Int     @id @default(autoincrement())
  field   String
  userId  Int?
  canRead Boolean @default(true)
  canEdit Boolean @default(false)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([field, userId])
}

model DepartmentAdmin {
  id      Int    @id @default(autoincrement())
  dept1   String
  company String
  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dept1, company, userId])
}

model CompanyCode {
  code    String  @id
  name    String  @unique
}

model DepartmentCode {
  code        String  @id  // 格式: companyCode+deptCode 如 "001001" / "004001"
  name        String
  companyCode String?
}

model PositionCode {
  code        String  @id  // 格式: companyCode+positionCode 如 "001001" / "004001"
  name        String
  companyCode String?
}

model UserPosition {
  id           String  @id
  userId       Int
  companyCode  String
  deptCode     String
  positionCode String
  isPrimary    Boolean @default(false)

  canSelectAnyWeek Boolean @default(false)
  canAccessWorks   Boolean @default(true)
  canAccessHR      Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
