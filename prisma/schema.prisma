generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 用户与认证 ───────────────────────────────────────────

model User {
  id               Int               @id @default(autoincrement()) // 主键
  wxUserId         String?           @unique // 微信用户ID（无微信则留空）
  username         String?           @unique // 登录用户名（自取）
  password         String? // 登录密码
  name             String // 名称
  avatar           String? // 头像URL
  routineItems     String? // 日常工作模板JSON
  canLogin         Boolean           @default(true)  // 离职=停用，不删号（账号状态，非权限）
  apiKey           String?           @unique // API密钥
  createdAt        DateTime          @default(now()) // 创建时间
  resourceRoles           UserResourceRole[]
  reports                 Report[]
  employees               Employee[]        @relation("EmployeeUser")
  editedEmployees         Employee[]        @relation("EmployeeEditor")
  managedDepartments      Department[]      @relation("DepartmentManager")
  editedDepartments       Department[]      @relation("DepartmentEditor")
  editedPositions         Position[]        @relation("PositionEditor")
  editedEmployeePositions EmployeePosition[] @relation("EmpPositionEditor")
  editedDepartmentPositions DepartmentPosition[] @relation("DeptPosEditor")
  editedCompanies         Company[]         @relation("CompanyEditor")
  editHistories           EditHistory[]     @relation("EditHistoryEditor")
  editedProjects          Project[]         @relation("ProjectEditor")
  editedEmployeeProjects  EmployeeProject[] @relation("EmpProjectEditor")
}

model SystemConfig {
  key   String @id
  value String
}

// ─── RBAC 权限 ────────────────────────────────────────────
// 详见 docs/rbac.md

model Resource {
  id              Int                      @id @default(autoincrement())
  key             String                   @unique
  name            String
  description     String?
  sortOrder       Int                      @default(0)
  parentId        Int?                     // 上级资源（资源树）
  parent          Resource?                @relation("ResHierarchy", fields: [parentId], references: [id])
  children        Resource[]               @relation("ResHierarchy")
  userRoles       UserResourceRole[]
  positionRoles   PositionResourceRole[]
  departmentRoles DepartmentResourceRole[]
}

model Role {
  id              Int    @id @default(autoincrement())
  key             String @unique   // "access" | "read" | "write" | "delete" | "admin"
  name            String
  description     String?
  sortOrder       Int    @default(0)
  userAssignments       UserResourceRole[]
  positionAssignments   PositionResourceRole[]
  departmentAssignments DepartmentResourceRole[]
}

model UserResourceRole {
  id         Int      @id @default(autoincrement())
  userId     Int
  resourceId Int
  roleId     Int
  scopeId    String?  // null=全局, 有值=范围实例
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId, roleId, scopeId])
}

model PositionResourceRole {
  id         Int      @id @default(autoincrement())
  positionId Int
  resourceId Int
  roleId     Int
  scopeId    String?
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([positionId, resourceId, roleId, scopeId])
}

model DepartmentResourceRole {
  id           Int        @id @default(autoincrement())
  departmentId Int
  resourceId   Int
  roleId       Int
  scopeId      String?
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([departmentId, resourceId, roleId, scopeId])
}

// ─── 报告模块 ─────────────────────────────────────────────

model Report {
  id            Int          @id @default(autoincrement()) // 主键
  userId        Int? // 用户ID
  targetType    String       @default("department") // "department" | "project" | "position"
  targetId      Int          @default(0) // 多态 FK → Department.id | Project.id | Position.id
  date          String // 日期（yyyy-MM-dd，日报=当天，周报=周一，月报=月初）
  taskName      String // 任务名称
  notes         String? // 备注
  version       Int          @default(1) // 版本号
  createdAt     DateTime     @default(now()) // 创建时间
  updatedAt     DateTime     @updatedAt // 更新时间
  history       ReportHistory[]
  items         ReportItem[]
  user          User?        @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId, date])
}

model ReportItem {
  id         Int          @id @default(autoincrement()) // 主键
  reportId   Int // 周报ID
  category   String // 分类
  plan       String // 本周计划
  completion String? // 完成情况
  nextGoal   String? // 下周目标
  sortOrder  Int // 排序序号
  workItemId Int? // 关联工作清单条目ID
  workItem   WorkItem?       @relation(fields: [workItemId], references: [id])
  report     Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id        Int          @id @default(autoincrement()) // 主键
  reportId  Int // 周报ID
  version   Int // 版本号
  taskName  String // 任务名称
  notes     String? // 备注
  itemsJson String // 条目JSON快照
  createdAt DateTime     @default(now()) // 创建时间
  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

// ─── 工作清单模块（独立） ─────────────────────────────────

model WorkItem {
  id           Int               @id @default(autoincrement()) // 主键
  targetType   String            @default("personal") // "project" | "department" | "position" | "personal"
  targetId     Int?                                      // 多态 FK
  category     String // 分类
  content      String // 内容
  importance   Int               @default(3) // 重要度（1-5）
  urgency      Int               @default(3) // 紧急度（1-5）
  isArchived   Boolean           @default(false) // 是否归档
  isPrivate    Boolean           @default(false)        // personal 时默认仅自己可见
  sortOrder    Int               @default(0) // 排序序号
  createdAt    DateTime          @default(now()) // 创建时间
  updatedAt    DateTime          @updatedAt // 更新时间
  participants WorkParticipant[]
  reportItems  ReportItem[]

  @@index([targetType, targetId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement()) // 主键
  workItemId Int // 关联工作清单条目ID
  name       String // 名称
  wxUserId   String? // 微信用户ID
  createdAt  DateTime @default(now()) // 创建时间
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

// ─── 花名册与组织架构 ─────────────────────────────────────

model Employee {
  id            Int                @id @default(autoincrement()) // 主键
  employeeId    String             @unique // 员工编号
  name          String // 名称
  alias         String? // 别名
  gender        String? // 性别
  ethnicity     String? // 民族
  hometown      String? // 籍贯
  politics      String? // 政治面貌
  education     String? // 学历
  title         String? // 职称
  school        String? // 毕业院校
  major         String? // 专业
  majorRelevant String? // 是否相关专业
  phone         String? // 电话
  office1       String? // 办公区1
  office2       String? // 办公区2
  office3       String? // 办公区3
  attendance1   String? // 考勤信息1
  attendance2   String? // 考勤信息2
  joinDate      String? // 进司时间
  nature        String? // 性质（全职/兼职等）
  createdAt     DateTime           @default(now()) // 创建时间
  updatedAt     DateTime           @updatedAt // 更新时间
  leaveDate     String? // 离职日期
  status        String?            @default("在职") // 状态
  deleted       Boolean?           @default(false) // 是否软删除
  deletedTime   String? // 删除时间
  deletedBy     String? // 删除操作人
  userId        Int? // 用户ID
  user          User?              @relation("EmployeeUser", fields: [userId], references: [id])
  positions     EmployeePosition[]
  projects      EmployeeProject[]
  editedBy      Int? // 编辑人用户ID
  editor        User?              @relation("EmployeeEditor", fields: [editedBy], references: [id])
  editedAt      DateTime? // 编辑时间
  version       Int                @default(1) // 版本号
}

model Company {
  id        Int       @id @default(autoincrement()) // 主键
  code      String    // 本级编码（一级: 0,1; 二级: 0,1,2,3...）
  name      String // 公司名称（父级内唯一）
  parentId  Int? // 上级公司ID（null=一级公司）
  parent    Company?  @relation("CompanyHierarchy", fields: [parentId], references: [id])
  children  Company[] @relation("CompanyHierarchy")
  sortOrder Int       @default(0) // 排序
  createdAt DateTime  @default(now()) // 创建时间
  updatedAt DateTime? // 更新时间
  editedBy  Int? // 编辑人用户ID
  editor    User?     @relation("CompanyEditor", fields: [editedBy], references: [id])
  editedAt  DateTime? // 编辑时间
  version   Int       @default(1) // 版本号

  @@unique([parentId, code])
  @@unique([parentId, name])
}

model Department {
  id                Int                @id @default(autoincrement()) // 主键
  code              String             @unique // 编码
  name              String // 名称
  level             Int // 层级
  parentId          Int? // 上级ID
  parent            Department?        @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]       @relation("DeptHierarchy")
  managerUserId     Int?               // 负责人 → User.id
  manager           User?              @relation("DepartmentManager", fields: [managerUserId], references: [id])
  positions         DepartmentPosition[]
  employeePositions EmployeePosition[]
  resourceRoles     DepartmentResourceRole[]
  projectDepartments ProjectDepartment[]
  company           String?            // 公司编码（如 01/02/03）
  createdAt         DateTime           @default(now()) // 创建时间
  updatedAt         DateTime? // 更新时间
  editedBy          Int? // 编辑人用户ID
  editor            User?              @relation("DepartmentEditor", fields: [editedBy], references: [id])
  editedAt          DateTime? // 编辑时间
  version           Int                @default(1) // 版本号
}

model Position {
  id                Int                @id @default(autoincrement()) // 主键
  code              String             @unique // 编码
  name              String // 名称
  company           String?            // 公司编码（如 01/02/03）
  departments       DepartmentPosition[]
  employeePositions EmployeePosition[]
  resourceRoles     PositionResourceRole[]
  createdAt         DateTime           @default(now()) // 创建时间
  updatedAt         DateTime? // 更新时间
  editedBy          Int? // 编辑人用户ID
  editor            User?              @relation("PositionEditor", fields: [editedBy], references: [id])
  editedAt          DateTime? // 编辑时间
  version           Int                @default(1) // 版本号
}

model EmployeePosition {
  id           Int        @id @default(autoincrement()) // 主键
  employeeId   Int // 员工编号
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentId Int // 部门ID
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   Int // 岗位ID
  position     Position   @relation(fields: [positionId], references: [id])
  company      String?     // 公司编码（如 01/02/03）
  center       String? // 中心
  isPrimary    Boolean    @default(false) // 是否主岗
  sortOrder    Int        @default(0) // 排序序号
  startDate    String?    // 任职开始日期
  endDate      String?    // 任职结束日期（null=至今）
  createdAt    DateTime   @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?         @relation("EmpPositionEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int        @default(1) // 版本号
}

model DepartmentPosition {
  id           Int          @id @default(autoincrement()) // 主键
  departmentId Int // 部门ID
  positionId   Int // 岗位ID
  company      String?      // 公司编码（如 01/02/03）
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position     Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?        @relation("DeptPosEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int          @default(1) // 版本号

  @@unique([departmentId, positionId])
}

model Project {
  id           Int              @id @default(autoincrement()) // 主键
  name         String // 项目名称
  type         String           @default("project") // "department" | "project"
  description  String? // 说明
  createdAt    DateTime         @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?            @relation("ProjectEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int              @default(1) // 版本号
  employees    EmployeeProject[]
  departments  ProjectDepartment[]
}

model ProjectDepartment {
  projectId    Int
  departmentId Int
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([projectId, departmentId])
}

model EmployeeProject {
  id         Int       @id @default(autoincrement()) // 主键
  employeeId Int // 员工ID
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId  Int // 项目ID
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role       String? // 项目角色
  startDate  String? // 开始日期
  endDate    String? // 结束日期
  createdAt  DateTime  @default(now()) // 创建时间
  updatedAt  DateTime? // 更新时间
  editedBy   Int? // 编辑人用户ID
  editor     User?     @relation("EmpProjectEditor", fields: [editedBy], references: [id])
  editedAt   DateTime? // 编辑时间
  version    Int       @default(1) // 版本号

  @@unique([employeeId, projectId])
}

// ─── 编辑历史 ─────────────────────────────────────────────

model EditHistory {
  id         Int      @id @default(autoincrement()) // 主键
  entityType String   // "employee" | "employee_position" | "code_department" | "code_position"
  entityId   String // 实体主键
  version    Int // 版本号
  dataJson   String   // 编辑前快照
  editedBy   Int // 编辑人用户ID
  editor     User     @relation("EditHistoryEditor", fields: [editedBy], references: [id])
  createdAt  DateTime @default(now()) // 创建时间

  @@unique([entityType, entityId, version])
}
