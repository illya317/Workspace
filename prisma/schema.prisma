generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 用户与认证 ───────────────────────────────────────────

model User {
  id               Int               @id @default(autoincrement()) // 主键
  wxUserId         String?           @unique // 微信用户ID（无微信则留空）
  username         String?           @unique // 登录用户名（自取）
  password         String? // 登录密码
  name             String // 名称
  avatar           String? // 头像URL
  routineItems     String? // 日常工作模板JSON
  canLogin         Boolean           @default(true)  // 离职=停用，不删号（账号状态，非权限）
  apiKey           String?           @unique // API密钥
  createdAt        DateTime          @default(now()) // 创建时间
  resourceRoles           UserResourceRole[]
  reports                 Report[]
  employees               Employee[]        @relation("EmployeeUser")
  editedEmployees         Employee[]        @relation("EmployeeEditor")
  managedDepartments      Department[]      @relation("DepartmentManager")
  editedDepartments       Department[]      @relation("DepartmentEditor")
  editedPositions         Position[]        @relation("PositionEditor")
  editedEmployeePositions EmployeeDepartmentPosition[] @relation("EmpDeptPositionEditor")
  editedCompanies         Company[]         @relation("CompanyEditor")
  editHistories           EditHistory[]     @relation("EditHistoryEditor")
  editedProjects          Project[]         @relation("ProjectEditor")
  editedEmployeeProjects  EmployeeProject[] @relation("EmpProjectEditor")
}

model SystemConfig {
  key   String @id
  value String
}

// ─── RBAC 权限 ────────────────────────────────────────────
// 详见 docs/rbac.md

model Resource {
  id              Int                      @id @default(autoincrement())
  key             String                   @unique
  name            String
  description     String?
  level           Int                      @default(1) // 1=父权限(无parentId), 2+=子权限
  sortOrder       Int                      @default(0)
  parentId        Int?                     // 上级资源（level≥2时必填）
  parent          Resource?                @relation("ResHierarchy", fields: [parentId], references: [id])
  children        Resource[]               @relation("ResHierarchy")
  userRoles       UserResourceRole[]
  positionRoles   PositionResourceRole[]
  departmentRoles DepartmentResourceRole[]
}

model Role {
  id              Int    @id @default(autoincrement())
  key             String @unique   // "access" | "read" | "write" | "delete" | "admin"
  name            String
  description     String?
  sortOrder       Int    @default(0)
  userAssignments       UserResourceRole[]
  positionAssignments   PositionResourceRole[]
  departmentAssignments DepartmentResourceRole[]
}

model UserResourceRole {
  id         Int      @id @default(autoincrement())
  userId     Int
  resourceId Int
  roleId     Int
  scopeId    String?  // null=全局, 有值=范围实例
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId, roleId, scopeId])
}

model PositionResourceRole {
  id         Int      @id @default(autoincrement())
  positionId Int
  resourceId Int
  roleId     Int
  scopeId    String?
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([positionId, resourceId, roleId, scopeId])
}

model DepartmentResourceRole {
  id           Int        @id @default(autoincrement())
  departmentId Int
  resourceId   Int
  roleId       Int
  scopeId      String?
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([departmentId, resourceId, roleId, scopeId])
}

// ─── 报告模块 ─────────────────────────────────────────────

model Report {
  id            Int          @id @default(autoincrement()) // 主键
  userId        Int? // 用户ID
  targetType    String       @default("department") // "department" | "project" | "position"
  targetId      Int          @default(0) // 多态 FK → Department.id | Project.id | Position.id
  date          String // 日期（yyyy-MM-dd，日报=当天，周报=周一，月报=月初）
  taskName      String // 任务名称
  notes         String? // 备注
  version       Int          @default(1) // 版本号
  createdAt     DateTime     @default(now()) // 创建时间
  updatedAt     DateTime     @updatedAt // 更新时间
  history       ReportHistory[]
  items         ReportItem[]
  user          User?        @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId, date])
}

model ReportItem {
  id         Int          @id @default(autoincrement()) // 主键
  reportId   Int // 周报ID
  category   String // 分类
  plan       String // 本周计划
  completion String? // 完成情况
  nextGoal   String? // 下周目标
  sortOrder  Int // 排序序号
  workItemId Int? // 关联工作清单条目ID
  workItem   WorkItem?       @relation(fields: [workItemId], references: [id])
  report     Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id        Int          @id @default(autoincrement()) // 主键
  reportId  Int // 周报ID
  version   Int // 版本号
  taskName  String // 任务名称
  notes     String? // 备注
  itemsJson String // 条目JSON快照
  createdAt DateTime     @default(now()) // 创建时间
  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

// ─── 工作清单模块（独立） ─────────────────────────────────

model WorkItem {
  id           Int               @id @default(autoincrement()) // 主键
  targetType   String            @default("personal") // "project" | "department" | "position" | "personal"
  targetId     Int?                                      // 多态 FK
  category     String // 分类
  content      String // 内容
  importance   Int               @default(3) // 重要度（1-5）
  urgency      Int               @default(3) // 紧急度（1-5）
  isArchived   Boolean           @default(false) // 是否归档
  isPrivate    Boolean           @default(false)        // personal 时默认仅自己可见
  sortOrder    Int               @default(0) // 排序序号
  createdAt    DateTime          @default(now()) // 创建时间
  updatedAt    DateTime          @updatedAt // 更新时间
  participants WorkParticipant[]
  reportItems  ReportItem[]

  @@index([targetType, targetId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement()) // 主键
  workItemId Int // 关联工作清单条目ID
  name       String // 名称
  wxUserId   String? // 微信用户ID
  createdAt  DateTime @default(now()) // 创建时间
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

// ─── 花名册与组织架构 ─────────────────────────────────────

model Employee {
  id            Int                @id @default(autoincrement()) // 主键
  employeeId    String             @unique // 员工编号
  idNumber      String?            @unique // 身份证号
  name          String // 名称
  alias         String? // 别名
  gender        String? // 性别
  birthDate     String? // 出生年月
  ethnicity     String? // 民族
  hometown      String? // 籍贯
  politics      String? // 政治面貌
  education     String? // 学历
  title         String? // 职称
  school        String? // 毕业院校
  major         String? // 专业
  phone         String? // 电话
  joinDate      String? // 进司时间
  workStartDate String? // 参加工作时间
  nature        String? // 性质（全职/兼职等）
  leaveDate     String? // 离职日期
  status        String?            @default("在职") // 状态
  details       String? // JSON: {companyTitle,majorRelevant,officeLocation,attendanceType,leaveReason,serviceYears,...}
  createdAt     DateTime           @default(now()) // 创建时间
  updatedAt     DateTime           @updatedAt // 更新时间
  deleted       Boolean?           @default(false) // 是否软删除
  deletedTime   String? // 删除时间
  deletedBy     String? // 删除操作人
  userId        Int? // 用户ID
  user          User?              @relation("EmployeeUser", fields: [userId], references: [id])
  positions     EmployeeDepartmentPosition[]
  projects      EmployeeProject[]
  editedBy      Int? // 编辑人用户ID
  editor        User?              @relation("EmployeeEditor", fields: [editedBy], references: [id])
  editedAt      DateTime? // 编辑时间
  version       Int                @default(1) // 版本号
}

model Company {
  id                 Int                @id @default(autoincrement()) // 主键
  code               String             @unique // 编码
  name               String             @unique // 名称
  fullName           String?            // 全称
  registeredCapital  String?            // 注册资本
  unifiedCode        String?            // 统一社会信用代码
  bankName           String?            // 开户行
  registeredAddress  String?            // 办公地址
  registeredDate     String?            // 注册时间
  legalPerson        String?            // 法定代表人
  queryGroup         Int?               // 1=丰华生物体系, 2=丰华制药
  sortOrder          Int                @default(0) // 排序
  createdAt          DateTime           @default(now()) // 创建时间
  updatedAt          DateTime?          // 更新时间
  editedBy           Int?               // 编辑人用户ID
  editor             User?              @relation("CompanyEditor", fields: [editedBy], references: [id])
  editedAt           DateTime?          // 编辑时间
  version            Int                @default(1) // 版本号

  parentOfRelations  CompanyRelation[]  @relation("ParentCompany")
  childOfRelations   CompanyRelation[]  @relation("ChildCompany")
}

model CompanyRelation {
  id             Int      @id @default(autoincrement())
  parentId       Int      // 持股方
  childId        Int      // 被持股方
  parent         Company  @relation("ParentCompany", fields: [parentId], references: [id], onDelete: Cascade)
  child          Company  @relation("ChildCompany", fields: [childId], references: [id], onDelete: Cascade)
  shareRatio     Float?   // 持股比例
  isConsolidated Boolean  @default(false) // 是否并表

  @@unique([parentId, childId])
}

model ManagementGroup {
  id          Int          @id @default(autoincrement())
  name        String       @unique // 常规体系, GMP
  departments Department[]
  positions   Position[]
  positionDescriptions PositionDescription[]
}

model Department {
  id                Int                @id @default(autoincrement()) // 主键
  code              String             // 编码
  name              String // 名称
  managementGroupId  Int?               // 体系ID
  managementGroup    ManagementGroup?   @relation(fields: [managementGroupId], references: [id])
  level             Int                @default(1) // 层级
  levelLabel        String             @default("部门") // 层级标签（中心/部门/子部门）
  parentId          Int? // 上级ID
  parent            Department?        @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]       @relation("DeptHierarchy")
  managerUserId     Int?               // 负责人 → User.id
  manager           User?              @relation("DepartmentManager", fields: [managerUserId], references: [id])
  positions         Position[]         // 岗位（1:N）
  employeeDepartmentPositions EmployeeDepartmentPosition[]
  resourceRoles     DepartmentResourceRole[]
  endDate           DateTime?          // 截止时间（null=至今）
  createdAt         DateTime           @default(now()) // 创建时间
  updatedAt         DateTime? // 更新时间
  editedBy          Int? // 编辑人用户ID
  editor            User?              @relation("DepartmentEditor", fields: [editedBy], references: [id])
  editedAt          DateTime? // 编辑时间
  version           Int                @default(1) // 版本号

  @@unique([managementGroupId, code])
}

model Position {
  id                    Int                     @id @default(autoincrement()) // 主键
  code                  String                  // 编码
  name                  String                  // 名称
  managementGroupId     Int?                    // 体系ID
  managementGroup       ManagementGroup?        @relation(fields: [managementGroupId], references: [id])
  departmentId          Int?                    // 所属部门
  department            Department?             @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  positionDescriptionId Int?                    // → PositionDescription.id
  positionDescription   PositionDescription?    @relation(fields: [positionDescriptionId], references: [id], onDelete: SetNull)
  employeeDepartmentPositions EmployeeDepartmentPosition[]
  resourceRoles         PositionResourceRole[]
  endDate               DateTime?               // 截止时间（null=至今）
  createdAt             DateTime                @default(now()) // 创建时间
  updatedAt             DateTime?               // 更新时间
  editedBy              Int?                    // 编辑人用户ID
  editor                User?                   @relation("PositionEditor", fields: [editedBy], references: [id])
  editedAt              DateTime?               // 编辑时间
  version               Int                     @default(1) // 版本号

  @@unique([managementGroupId, code])
}

model EmployeeDepartmentPosition {
  id           Int        @id @default(autoincrement()) // 主键
  employeeId   Int // 员工编号
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentId Int? // 部门ID
  department   Department? @relation(fields: [departmentId], references: [id])
  positionId   Int? // 岗位ID
  position     Position?   @relation(fields: [positionId], references: [id])
  center       String? // 中心
  isPrimary    Boolean    @default(false) // 是否主岗
  sortOrder    Int        @default(0) // 排序序号
  startDate    String?    // 任职开始日期
  endDate      String?    // 任职结束日期（null=至今）
  createdAt    DateTime   @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?         @relation("EmpDeptPositionEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int        @default(1) // 版本号

  @@map("EmployeePosition")
}

model Project {
  id           Int              @id @default(autoincrement()) // 主键
  name         String // 项目名称
  type         String           @default("project") // "department" | "project"
  description  String? // 说明
  endDate      DateTime?        // 截止时间（null=至今）
  createdAt    DateTime         @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?            @relation("ProjectEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int              @default(1) // 版本号
  employees    EmployeeProject[]
}

model EmployeeProject {
  id         Int       @id @default(autoincrement()) // 主键
  employeeId Int // 员工ID
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId  Int // 项目ID
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role       String? // 项目角色
  startDate  String? // 开始日期
  endDate    String? // 结束日期
  createdAt  DateTime  @default(now()) // 创建时间
  updatedAt  DateTime? // 更新时间
  editedBy   Int? // 编辑人用户ID
  editor     User?     @relation("EmpProjectEditor", fields: [editedBy], references: [id])
  editedAt   DateTime? // 编辑时间
  version    Int       @default(1) // 版本号

  @@unique([employeeId, projectId])
}

// ─── 岗位说明书 ───────────────────────────────────────────

model PositionDescription {
  id                Int              @id @default(autoincrement())
  code              String           @unique // PPA-GW0101
  name              String           // 岗位名称
  departmentName    String?          // 所属部门
  reportTo          String?          // 直接上级
  positionPurpose   String?          // 岗位目的（一句话）
  summary           String?          // 职责概要（一段话）
  headcount         Int?             // 编制人数
  version           String?          // 版本号
  effectiveDate     String?          // 生效日期
  sourceFile        String           // 原始JSON文件名
  managementGroupId Int              // → ManagementGroup.id
  managementGroup   ManagementGroup  @relation(fields: [managementGroupId], references: [id])
  details           String?          // JSON: {duties, qualifications, conditions, collaborations, changeHistory, ...}
  positions         Position[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

// ─── 编辑历史 ─────────────────────────────────────────────
model EditHistory {
  id         Int      @id @default(autoincrement()) // 主键
  entityType String   // "employee" | "employee_position" | "code_department" | "code_position"
  entityId   String // 实体主键
  version    Int // 版本号
  dataJson   String   // 编辑前快照
  editedBy   Int // 编辑人用户ID
  editor     User     @relation("EditHistoryEditor", fields: [editedBy], references: [id])
  createdAt  DateTime @default(now()) // 创建时间

  @@unique([entityType, entityId, version])
}

// ─── 登录安全 ───────────────────────────────────────────────
model LoginAttempt {
  id        Int      @id @default(autoincrement())
  username  String   // 尝试登录的用户名
  ip        String   // 客户端IP
  success   Boolean  // 是否成功
  createdAt DateTime @default(now())
}
