generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  wxUserId           String            @unique
  username           String?           @unique
  password           String?
  name               String
  company            String?
  departmentId       Int
  departmentName     String?
  avatar             String?
  routineItems       String?
  isWorkListAdmin    Boolean           @default(false)
  canSelectAnyWeek   Boolean           @default(false)
  canAccessHR        Boolean           @default(false)
  canAccessWorks     Boolean           @default(true)
  employeeId         String?
  canLogin           Boolean           @default(true)
  apiKey             String?           @unique
  createdAt          DateTime          @default(now())
  managedDepartments DepartmentAdmin[]
  fieldPermissions   FieldPermission[]
  positions          UserPosition[]
  reports            WeeklyReport[]
  employees          Employee[]
}

model ReportGroup {
  id           Int                 @id @default(autoincrement())
  name         String
  description  String?
  sortOrder    Int                 @default(0)
  departmentId Int?
  department   Department?         @relation(fields: [departmentId], references: [id])
  createdAt    DateTime            @default(now())
  admins       ReportGroupAdmin[]
  members      ReportGroupMember[]
  viewers      ReportGroupViewer[]
  reports      WeeklyReport[]
}

model ReportGroupAdmin {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  userId        Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)

  @@unique([reportGroupId, userId])
}

model ReportGroupMember {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  userId        Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)

  @@unique([reportGroupId, userId])
}

model ReportGroupViewer {
  id            Int         @id @default(autoincrement())
  reportGroupId Int
  userId        Int
  reportGroup   ReportGroup @relation(fields: [reportGroupId], references: [id], onDelete: Cascade)

  @@unique([reportGroupId, userId])
}

model WeeklyReport {
  id            Int             @id @default(autoincrement())
  userId        Int?
  reportGroupId Int?
  weekNumber    Int
  year          Int
  periodType    String          @default("weekly")
  scopeType     String          @default("department")
  scopeId       Int
  taskName      String
  notes         String?
  version       Int             @default(1)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  history       ReportHistory[]
  items         ReportItem[]
  reportGroup   ReportGroup?    @relation(fields: [reportGroupId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])

  @@unique([scopeType, scopeId, periodType, year, weekNumber])
}

model ReportItem {
  id         Int          @id @default(autoincrement())
  reportId   Int
  category   String
  plan       String
  completion String?
  nextGoal   String?
  sortOrder  Int
  workItemId Int?
  report     WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id        Int          @id @default(autoincrement())
  reportId  Int
  version   Int
  taskName  String
  notes     String?
  itemsJson String
  createdAt DateTime     @default(now())
  report    WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

model WorkItem {
  id           Int               @id @default(autoincrement())
  departmentId Int
  category     String
  content      String
  importance   Int               @default(3)
  urgency      Int               @default(3)
  isArchived   Boolean           @default(false)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  participants WorkParticipant[]

  @@index([departmentId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement())
  workItemId Int
  name       String
  wxUserId   String?
  createdAt  DateTime @default(now())
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

// 保留旧 Employee 表完整结构（数据迁移前不删除字段）
model Employee {
  id            Int      @id @default(autoincrement())
  employeeId    String   @unique
  name          String
  alias         String?
  company       String?
  center        String?
  dept1         String?
  dept2         String?
  position      String?
  gender        String?
  ethnicity     String?
  hometown      String?
  politics      String?
  education     String?
  title         String?
  school        String?
  major         String?
  majorRelevant String?
  phone         String?
  office1       String?
  office2       String?
  office3       String?
  attendance1   String?
  attendance2   String?
  joinDate      String?
  nature        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  leaveDate     String?
  status        String?  @default("在职")
  deleted       Boolean? @default(false)
  deletedTime   String?
  deletedBy     String?
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id])
  positions     EmployeePosition[]
}

// 新增部门表
model Department {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  name              String
  company           String
  level             Int
  parentId          Int?
  parent            Department?        @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]       @relation("DeptHierarchy")
  managerId         String?
  positions         DepartmentPosition[]
  employeePositions EmployeePosition[]
  reportGroups      ReportGroup[]
  createdAt         DateTime           @default(now())
}

// 新增岗位表
model Position {
  id                Int                @id @default(autoincrement())
  code              String             @unique
  name              String
  company           String
  departments       DepartmentPosition[]
  employeePositions EmployeePosition[]
  createdAt         DateTime           @default(now())
}

// 新增员工岗位关联表
model EmployeePosition {
  id           Int        @id @default(autoincrement())
  employeeId   Int
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   Int
  position     Position   @relation(fields: [positionId], references: [id])
  center       String?
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
}

// 新增部门-岗位配置表
model DepartmentPosition {
  id           Int        @id @default(autoincrement())
  departmentId Int
  positionId   Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position     Position   @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([departmentId, positionId])
}

model FieldPermission {
  id      Int     @id @default(autoincrement())
  field   String
  userId  Int?
  canRead Boolean @default(true)
  canEdit Boolean @default(false)
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([field, userId])
}

model DepartmentAdmin {
  id      Int    @id @default(autoincrement())
  dept1   String
  company String
  userId  Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([dept1, company, userId])
}

model CompanyCode {
  code String @id
  name String @unique
}

model DepartmentCode {
  code        String  @id
  name        String
  companyCode String?
}

model PositionCode {
  code        String  @id
  name        String
  companyCode String?
}

model UserPosition {
  id               String  @id
  userId           Int
  companyCode      String
  deptCode         String
  positionCode     String
  isPrimary        Boolean @default(false)
  canSelectAnyWeek Boolean @default(false)
  canAccessWorks   Boolean @default(true)
  canAccessHR      Boolean @default(false)
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
