generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── 用户与认证 ───────────────────────────────────────────

model User {
  id               Int               @id @default(autoincrement()) // 主键
  wxUserId         String?           @unique // 微信用户ID（无微信则留空）
  username         String?           @unique // 登录用户名（自取）
  password         String? // 登录密码
  name             String // 名称
  avatar           String? // 头像URL
  routineItems     String? // 日常工作模板JSON
  canLogin         Boolean           @default(true)  // 离职=停用，不删号（账号状态，非权限）
  apiKey           String?           @unique // API密钥
  createdAt        DateTime          @default(now()) // 创建时间
  resourceRoles           UserResourceRole[]
  reports                 Report[]
  employees               Employee[]        @relation("EmployeeUser")
  editedEmployees         Employee[]        @relation("EmployeeEditor")
  managedDepartments      Department[]      @relation("DepartmentManager")
  editedDepartments       Department[]      @relation("DepartmentEditor")
  editedPositions         Position[]        @relation("PositionEditor")
  editedEmployeePositions EmployeePosition[] @relation("EmpPositionEditor")
  editedDepartmentPositions DepartmentPosition[] @relation("DeptPosEditor")
  editedCompanies         Company[]         @relation("CompanyEditor")
  editHistories           EditHistory[]     @relation("EditHistoryEditor")
  editedProjects          Project[]         @relation("ProjectEditor")
  editedEmployeeProjects  EmployeeProject[] @relation("EmpProjectEditor")
  editedPositionDescriptions PositionDescription[] @relation("PosDescEditor")
}

model SystemConfig {
  key   String @id
  value String
}

// ─── RBAC 权限 ────────────────────────────────────────────
// 详见 docs/rbac.md

model Resource {
  id              Int                      @id @default(autoincrement())
  key             String                   @unique
  name            String
  description     String?
  level           Int                      @default(1) // 1=父权限(无parentId), 2+=子权限
  sortOrder       Int                      @default(0)
  parentId        Int?                     // 上级资源（level≥2时必填）
  parent          Resource?                @relation("ResHierarchy", fields: [parentId], references: [id])
  children        Resource[]               @relation("ResHierarchy")
  userRoles       UserResourceRole[]
  positionRoles   PositionResourceRole[]
  departmentRoles DepartmentResourceRole[]
}

model Role {
  id              Int    @id @default(autoincrement())
  key             String @unique   // "access" | "read" | "write" | "delete" | "admin"
  name            String
  description     String?
  sortOrder       Int    @default(0)
  userAssignments       UserResourceRole[]
  positionAssignments   PositionResourceRole[]
  departmentAssignments DepartmentResourceRole[]
}

model UserResourceRole {
  id         Int      @id @default(autoincrement())
  userId     Int
  resourceId Int
  roleId     Int
  scopeId    String?  // null=全局, 有值=范围实例
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId, roleId, scopeId])
}

model PositionResourceRole {
  id         Int      @id @default(autoincrement())
  positionId Int
  resourceId Int
  roleId     Int
  scopeId    String?
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([positionId, resourceId, roleId, scopeId])
}

model DepartmentResourceRole {
  id           Int        @id @default(autoincrement())
  departmentId Int
  resourceId   Int
  roleId       Int
  scopeId      String?
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  resource     Resource   @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([departmentId, resourceId, roleId, scopeId])
}

// ─── 报告模块 ─────────────────────────────────────────────

model Report {
  id            Int          @id @default(autoincrement()) // 主键
  userId        Int? // 用户ID
  targetType    String       @default("department") // "department" | "project" | "position"
  targetId      Int          @default(0) // 多态 FK → Department.id | Project.id | Position.id
  date          String // 日期（yyyy-MM-dd，日报=当天，周报=周一，月报=月初）
  taskName      String // 任务名称
  notes         String? // 备注
  version       Int          @default(1) // 版本号
  createdAt     DateTime     @default(now()) // 创建时间
  updatedAt     DateTime     @updatedAt // 更新时间
  history       ReportHistory[]
  items         ReportItem[]
  user          User?        @relation(fields: [userId], references: [id])

  @@unique([userId, targetType, targetId, date])
}

model ReportItem {
  id         Int          @id @default(autoincrement()) // 主键
  reportId   Int // 周报ID
  category   String // 分类
  plan       String // 本周计划
  completion String? // 完成情况
  nextGoal   String? // 下周目标
  sortOrder  Int // 排序序号
  workItemId Int? // 关联工作清单条目ID
  workItem   WorkItem?       @relation(fields: [workItemId], references: [id])
  report     Report    @relation(fields: [reportId], references: [id], onDelete: Cascade)
}

model ReportHistory {
  id        Int          @id @default(autoincrement()) // 主键
  reportId  Int // 周报ID
  version   Int // 版本号
  taskName  String // 任务名称
  notes     String? // 备注
  itemsJson String // 条目JSON快照
  createdAt DateTime     @default(now()) // 创建时间
  report    Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, version])
}

// ─── 工作清单模块（独立） ─────────────────────────────────

model WorkItem {
  id           Int               @id @default(autoincrement()) // 主键
  targetType   String            @default("personal") // "project" | "department" | "position" | "personal"
  targetId     Int?                                      // 多态 FK
  category     String // 分类
  content      String // 内容
  importance   Int               @default(3) // 重要度（1-5）
  urgency      Int               @default(3) // 紧急度（1-5）
  isArchived   Boolean           @default(false) // 是否归档
  isPrivate    Boolean           @default(false)        // personal 时默认仅自己可见
  sortOrder    Int               @default(0) // 排序序号
  createdAt    DateTime          @default(now()) // 创建时间
  updatedAt    DateTime          @updatedAt // 更新时间
  participants WorkParticipant[]
  reportItems  ReportItem[]

  @@index([targetType, targetId, category])
}

model WorkParticipant {
  id         Int      @id @default(autoincrement()) // 主键
  workItemId Int // 关联工作清单条目ID
  name       String // 名称
  wxUserId   String? // 微信用户ID
  createdAt  DateTime @default(now()) // 创建时间
  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@index([workItemId])
}

// ─── 花名册与组织架构 ─────────────────────────────────────

model Employee {
  id            Int                @id @default(autoincrement()) // 主键
  employeeId    String             @unique // 员工编号
  name          String // 名称
  alias         String? // 别名
  gender        String? // 性别
  ethnicity     String? // 民族
  hometown      String? // 籍贯
  politics      String? // 政治面貌
  education     String? // 学历
  title         String? // 职称
  school        String? // 毕业院校
  major         String? // 专业
  phone         String? // 电话
  joinDate      String? // 进司时间
  nature        String? // 性质（全职/兼职等）
  createdAt     DateTime           @default(now()) // 创建时间
  updatedAt     DateTime           @updatedAt // 更新时间
  leaveDate     String? // 离职日期
  status        String?            @default("在职") // 状态
  deleted       Boolean?           @default(false) // 是否软删除
  deletedTime   String? // 删除时间
  deletedBy     String? // 删除操作人
  userId        Int? // 用户ID
  user          User?              @relation("EmployeeUser", fields: [userId], references: [id])
  positions     EmployeePosition[]
  projects      EmployeeProject[]
  editedBy      Int? // 编辑人用户ID
  editor        User?              @relation("EmployeeEditor", fields: [editedBy], references: [id])
  editedAt      DateTime? // 编辑时间
  version       Int                @default(1) // 版本号
}

model Company {
  id                 Int                @id @default(autoincrement()) // 主键
  code               String             @unique // 编码
  name               String             @unique // 名称
  fullName           String?            // 全称
  registeredCapital  String?            // 注册资本
  unifiedCode        String?            // 统一社会信用代码
  bankName           String?            // 开户行
  registeredAddress  String?            // 办公地址
  registeredDate     String?            // 注册时间
  legalPerson        String?            // 法定代表人
  managementGroup    String?            // 管理体系（丰华生物体系/丰华制药）
  sortOrder          Int                @default(0) // 排序
  createdAt          DateTime           @default(now()) // 创建时间
  updatedAt          DateTime?          // 更新时间
  editedBy           Int?               // 编辑人用户ID
  editor             User?              @relation("CompanyEditor", fields: [editedBy], references: [id])
  editedAt           DateTime?          // 编辑时间
  version            Int                @default(1) // 版本号

  parentOfRelations  CompanyRelation[]  @relation("ParentCompany")
  childOfRelations   CompanyRelation[]  @relation("ChildCompany")
}

model CompanyRelation {
  id             Int      @id @default(autoincrement())
  parentId       Int      // 持股方
  childId        Int      // 被持股方
  parent         Company  @relation("ParentCompany", fields: [parentId], references: [id], onDelete: Cascade)
  child          Company  @relation("ChildCompany", fields: [childId], references: [id], onDelete: Cascade)
  shareRatio     Float?   // 持股比例
  isConsolidated Boolean  @default(false) // 是否并表

  @@unique([parentId, childId])
}

model Department {
  id                Int                @id @default(autoincrement()) // 主键
  code              String             @unique // 编码
  name              String // 名称
  level             Int // 层级
  parentId          Int? // 上级ID
  parent            Department?        @relation("DeptHierarchy", fields: [parentId], references: [id])
  children          Department[]       @relation("DeptHierarchy")
  managerUserId     Int?               // 负责人 → User.id
  manager           User?              @relation("DepartmentManager", fields: [managerUserId], references: [id])
  positions         DepartmentPosition[]
  employeePositions EmployeePosition[]
  resourceRoles     DepartmentResourceRole[]
  projectDepartments ProjectDepartment[]
  managementGroup    String             @map("company") // 管理体系（丰华生物体系/丰华制药）
  createdAt         DateTime           @default(now()) // 创建时间
  updatedAt         DateTime? // 更新时间
  editedBy          Int? // 编辑人用户ID
  editor            User?              @relation("DepartmentEditor", fields: [editedBy], references: [id])
  editedAt          DateTime? // 编辑时间
  version           Int                @default(1) // 版本号
}

model Position {
  id                Int                @id @default(autoincrement()) // 主键
  code              String             @unique // 编码
  name              String // 名称
  managementGroup    String             @map("company") // 管理体系（丰华生物体系/丰华制药）
  departments       DepartmentPosition[]
  employeePositions EmployeePosition[]
  resourceRoles     PositionResourceRole[]
  createdAt         DateTime           @default(now()) // 创建时间
  updatedAt         DateTime? // 更新时间
  editedBy          Int? // 编辑人用户ID
  editor            User?              @relation("PositionEditor", fields: [editedBy], references: [id])
  editedAt          DateTime? // 编辑时间
  version           Int                @default(1) // 版本号
}

model EmployeePosition {
  id           Int        @id @default(autoincrement()) // 主键
  employeeId   Int // 员工编号
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  departmentId Int // 部门ID
  department   Department @relation(fields: [departmentId], references: [id])
  positionId   Int // 岗位ID
  position     Position   @relation(fields: [positionId], references: [id])
  managementGroup    String?     @map("company") // 管理体系（丰华生物体系/丰华制药）
  center       String? // 中心
  isPrimary    Boolean    @default(false) // 是否主岗
  sortOrder    Int        @default(0) // 排序序号
  startDate    String?    // 任职开始日期
  endDate      String?    // 任职结束日期（null=至今）
  createdAt    DateTime   @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?         @relation("EmpPositionEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int        @default(1) // 版本号
}

model DepartmentPosition {
  id           Int          @id @default(autoincrement()) // 主键
  departmentId Int // 部门ID
  positionId   Int // 岗位ID
  managementGroup    String?      @map("company") // 管理体系
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position     Position     @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt    DateTime     @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?        @relation("DeptPosEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int          @default(1) // 版本号

  @@unique([departmentId, positionId])
}

model Project {
  id           Int              @id @default(autoincrement()) // 主键
  name         String // 项目名称
  type         String           @default("project") // "department" | "project"
  description  String? // 说明
  createdAt    DateTime         @default(now()) // 创建时间
  updatedAt    DateTime? // 更新时间
  editedBy     Int? // 编辑人用户ID
  editor       User?            @relation("ProjectEditor", fields: [editedBy], references: [id])
  editedAt     DateTime? // 编辑时间
  version      Int              @default(1) // 版本号
  employees    EmployeeProject[]
  departments  ProjectDepartment[]
}

model ProjectDepartment {
  projectId    Int
  departmentId Int
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([projectId, departmentId])
}

model EmployeeProject {
  id         Int       @id @default(autoincrement()) // 主键
  employeeId Int // 员工ID
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId  Int // 项目ID
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role       String? // 项目角色
  startDate  String? // 开始日期
  endDate    String? // 结束日期
  createdAt  DateTime  @default(now()) // 创建时间
  updatedAt  DateTime? // 更新时间
  editedBy   Int? // 编辑人用户ID
  editor     User?     @relation("EmpProjectEditor", fields: [editedBy], references: [id])
  editedAt   DateTime? // 编辑时间
  version    Int       @default(1) // 版本号

  @@unique([employeeId, projectId])
}

// ─── 制药岗位说明书 ─────────────────────────────────────

model PositionDescription {
  id                    Int       @id @default(autoincrement())
  code                  String    @unique // 岗位编号（如 0101，去PPA-GW前缀）
  name                  String    // 岗位名称
  positionName          String?   // 岗位名称（关联 Position.name）
  departmentName        String?   // 所属部门名称
  purpose               String?   // 文档目的
  scope                 String?   // 适用范围
  reportTo              String?   // 直接上级
  subordinates          String?   // 直接下级
  headcount             Int?      // 岗位编制人数
  positionPurpose       String?   // 岗位目的
  summary               String?   // 岗位职责概要
  dutyOverview          String?   // 职责概述
  externalCollaboration String?   // 外部协作关系
  qualificationsJson    String?   // 任职资质 JSON
  conditionsJson        String?   // 工作条件 JSON
  documentSource        String    // 原文件名
  documentNumber        String?   // 文档编号
  version               String?   // 版本号
  effectiveDate         String?   // 生效日期
  drafter               String?   // 起草人
  reviewer1             String?   // 审核人1
  reviewer2             String?   // 审核人2
  approver              String?   // 批准人
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  editedBy              Int?
  editor                User?     @relation("PosDescEditor", fields: [editedBy], references: [id])
  editedAt              DateTime?

  duties            PositionDuty[]
  changeHistories   PositionChangeHistory[]
}

model PositionDuty {
  id                    Int                 @id @default(autoincrement())
  positionDescriptionId Int
  content               String
  sortOrder             Int                 @default(0)
  positionDescription   PositionDescription @relation(fields: [positionDescriptionId], references: [id], onDelete: Cascade)
}

model PositionChangeHistory {
  id                    Int                 @id @default(autoincrement())
  positionDescriptionId Int
  version               String
  documentName          String?
  effectiveDate         String?
  approver              String?
  sortOrder             Int                 @default(0)
  positionDescription   PositionDescription @relation(fields: [positionDescriptionId], references: [id], onDelete: Cascade)
}

// ─── 丰华制药花名册导入 ─────────────────────────────────

model PharmaRoster {
  id                Int      @id @default(autoincrement())
  isNew             Boolean  @default(true)
  source            String   @default("在职") // 在职 | 离职
  sequence          Int?     // 序号
  subSequence       Int?     // 分序号
  nature            String?  // 性质
  platform          String?  // 事业部/职能平台
  name              String   // 姓名
  isResearch        String?  // 科技研发
  personnelType     String?  // 人员类型
  department        String?  // 部门
  position          String?  // 职务/岗位（新）
  primaryPosition   String?  // 主要岗位
  secondaryPosition String?  // 次要岗位
  rank              String?  // 职级
  employeeNumber    String?  // 编号
  hometown          String?  // 籍贯
  idNumber          String?  // 身份证号码
  politicsStatus    String?  // 政治面貌
  ethnicity         String?  // 民族
  education         String?  // 学历
  school            String?  // 毕业院校
  major             String?  // 专业
  majorRelevant     String?  // 是否相关专业
  title             String?  // 职称
  companyTitle      String?  // 职称（公司评定）
  phone             String?  // 电话
  gender            String?  // 性别
  birthDate         String?  // 出生年月
  birthMonth        String?  // 生日月份
  age               Int?     // 年龄
  retireDate        String?  // 退休日期
  workStartDate     String?  // 参加工作时间
  joinDate          String?  // 进司时间
  serviceYears      String?  // 司龄
  serviceYearsNum   Int?     // 司龄（年）
  leaveDate         String?  // 离职时间
  tenureAtCompany   String?  // 在职时间
  originalRow       String?   // 原始行JSON（保留完整数据）
  createdAt         DateTime @default(now())
}

// ─── 编辑历史 ─────────────────────────────────────────────

model EditHistory {
  id         Int      @id @default(autoincrement()) // 主键
  entityType String   // "employee" | "employee_position" | "code_department" | "code_position"
  entityId   String // 实体主键
  version    Int // 版本号
  dataJson   String   // 编辑前快照
  editedBy   Int // 编辑人用户ID
  editor     User     @relation("EditHistoryEditor", fields: [editedBy], references: [id])
  createdAt  DateTime @default(now()) // 创建时间

  @@unique([entityType, entityId, version])
}
