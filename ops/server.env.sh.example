# 生产服务器配置
# 复制此文件为 server.env.sh 并填入真实值
# server.env.sh 已被 .gitignore 忽略，禁止提交

SERVER="ubuntu@YOUR_SERVER_IP"
REMOTE_DIR="/home/ubuntu/workspace"
PM2_NAME="workspace"
DEPLOY_TARGET="production"

# 运行态配置目录同步（二选一：默认会用本机 $WORKSPACE_CONFIG_DIR，其次 $HOME/.workspace）
# LOCAL_WORKSPACE_CONFIG_DIR="/Users/koito/Desktop/workspace/.workspace"
# LOCAL_WORKSPACE_BACKUP_DIR="/Users/koito/Desktop/workspace/.workspace.backups"
#
# 远端运行态配置目录，保持在源码目录外，避免 Next/Turbopack 构建扫描项目根 data 软链。
# REMOTE_WORKSPACE_CONFIG_DIR="/home/ubuntu/.workspace"
# REMOTE_WORKSPACE_BACKUP_DIR="/home/ubuntu/.workspace.backups"

# SSH 密钥（二选一）：
# A) 密钥内容直接写入（推荐，不依赖本地文件路径）
# KEY_CONTENT="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
#
# B) 本地密钥文件路径（旧方式）
# KEY="/path/to/your/private-key.pem"

# CI/云效自动部署建议改用环境变量注入，而不是提交 server.env.sh：
# SERVER="ubuntu@YOUR_SERVER_IP"
# REMOTE_DIR="/home/ubuntu/workspace"
# PM2_NAME="workspace"
# KEY_CONTENT="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
# REMOTE_WORKSPACE_CONFIG_DIR="/home/ubuntu/.workspace"
# HEALTHCHECK_URL="http://127.0.0.1:3000/"
