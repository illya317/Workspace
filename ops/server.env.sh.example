# 生产服务器配置
# 复制此文件为 server.env.sh 并填入真实值
# server.env.sh 已被 .gitignore 忽略，禁止提交

SERVER="ubuntu@YOUR_SERVER_IP"
REMOTE_DIR="/home/ubuntu/workspace"
PM2_NAME="workspace"
DEPLOY_TARGET="production"

# 运行态配置目录同步：默认使用源码 checkout 旁边的 .workspace
# LOCAL_WORKSPACE_CONFIG_DIR="/Users/koito/Project/workspace/.workspace"
# LOCAL_WORKSPACE_BACKUP_DIR="/Users/koito/Project/workspace/.workspace.backups"
#
# 远端运行态配置目录，和本地保持同一层级架构。
# REMOTE_WORKSPACE_CONFIG_DIR="/home/ubuntu/workspace/.workspace"
# REMOTE_WORKSPACE_BACKUP_DIR="/home/ubuntu/workspace/.workspace.backups"

# SSH 密钥（二选一）：
# A) 密钥内容直接写入（推荐，不依赖本地文件路径）
# KEY_CONTENT="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
#
# B) 本地密钥文件路径（旧方式）
# KEY="/path/to/your/private-key.pem"

# CI/云效自动部署建议改用环境变量注入，而不是提交 server.env.sh：
# SERVER="ubuntu@YOUR_SERVER_IP"
# REMOTE_DIR="/home/ubuntu/workspace"
# PM2_NAME="workspace"
# KEY_CONTENT="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
# REMOTE_WORKSPACE_CONFIG_DIR="/home/ubuntu/workspace/.workspace"
# HEALTHCHECK_URL="http://127.0.0.1:3000/"

# 手动从服务器拉回运行态 data（会先备份本地 .workspace）：
# npm run workspace:pull
# npm run workspace:pull -- --dry-run
# npm run workspace:pull -- --assets
